---
import TagList from "./TagList.astro";
import type { Project } from "@data/projects";

const { project } = Astro.props as { project: Project };
---

<article class="card project-card">
  <div class="card-body">
    <div class="project-meta">
      <h3>{project.shortTitle ?? project.title}</h3>
      <span class="project-status">{project.status}</span>
    </div>
    <p>{project.summary}</p>
    <TagList tags={project.tags.slice(0, 5)} />
    {project.preprint && <p class="preprint-note">Preprint DOI: {project.preprint.doi}</p>}
    <div class="link-list" aria-label={`${project.title} links`}>
      {
        project.links
          .slice(0, 2)
          .map((link) => (
            <a href={link.url} target="_blank" rel="noreferrer" aria-label={`${link.label} (opens in a new tab)`}>
              {link.kind === "code" ? "Code" : link.kind === "paper" ? "Preprint" : "Docs"}
            </a>
          ))
      }
    </div>
  </div>
</article>
